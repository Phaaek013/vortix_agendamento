# Configurações da API Backend
VITE_API_BASE_URL="http://localhost:3000/api/v1"

# Configurações de Ambiente (development, staging, production)
VITE_APP_ENV="development"

# Chaves Públicas (Exemplo: Analytics, Gateways de Pagamento)
VITE_STRIPE_PUBLIC_KEY="pk_test_xxxxxxxxxxxxxxxxxxxx"
VITE_GOOGLE_ANALYTICS_ID="G-XXXXXXXXXX"

# Configurações da Clínica (White-label / Multi-tenant defaults)
VITE_CLINIC_NAME="ClinicOps Hub"
VITE_SUPPORT_EMAIL="suporte@clinicops.com"

# IMPORTANTE: Nunca coloque chaves secretas, senhas ou tokens privados no React/Vite.
# As variáveis iniciadas em VITE_ são expostas no bundle do navegador.
